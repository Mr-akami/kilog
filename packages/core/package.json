{
  "name": "@kilog/core",
  "version": "1.1.2",
  "description": "Core library for kilog structured logging",
  "keywords": [
    "duckdb",
    "kilog",
    "logging",
    "structured-logging"
  ],
  "homepage": "https://github.com/Mr-akami/kilog/tree/main/packages/core#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mr-akami/kilog.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ansi": {
      "types": "./dist/ansi.d.ts",
      "import": "./dist/ansi.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "test": "vp test run"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.2-r.1"
  }
}
