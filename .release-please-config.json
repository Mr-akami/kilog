{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "packages": {
    "packages/core": {
      "component": "@kilog/core"
    },
    "packages/runtime-node": {
      "component": "@kilog/runtime-node"
    },
    "packages/vite-plugin": {
      "component": "@kilog/vite-plugin"
    },
    "packages/cli": {
      "component": "@kilog/cli"
    },
    "packages/web-ui": {
      "component": "@kilog/web-ui"
    },
    "packages/register": {
      "component": "@kilog/register"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "kilog-core",
      "components": ["@kilog/core", "@kilog/runtime-node"]
    }
  ]
}
