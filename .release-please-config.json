{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "packages": {
    "packages/core": {
      "component": "@logit/core"
    },
    "packages/runtime-node": {
      "component": "@logit/runtime-node"
    },
    "packages/vite-plugin": {
      "component": "@logit/vite-plugin"
    },
    "packages/cli": {
      "component": "@logit/cli"
    },
    "packages/web-ui": {
      "component": "@logit/web-ui"
    },
    "packages/register": {
      "component": "@logit/register"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "logit-core",
      "components": ["@logit/core", "@logit/runtime-node"]
    }
  ]
}
